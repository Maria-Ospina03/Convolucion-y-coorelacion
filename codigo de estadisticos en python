#------------------------------------------------------------------------
def filtrar_eog(signal, fs):
    low = 0.1/(fs/2)
    high = 10/(fs/2)
    b,a = butter(3,[low,high],btype='band')
    return filtfilt(b,a,signal)


#---------------------------------------------------------------------
def escalar_adc(valor):
        # 0 → -1.5
        # 4095 → +1.5
        return (valor / 4095.0) * 3.0 - 1.5 

